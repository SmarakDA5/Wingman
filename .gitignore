```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build directories
dist/

# Temporary files
node_modules/.tmp/

# Package lock files
package-lock.json

# IDE specific files
node_modules/.package-lock.json
build/
target/
coverage/
htmlcov/
.mypy_cache/
.pytest_cache/
.gradle/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/

# System files
.DS_Store
Thumbs.db
```