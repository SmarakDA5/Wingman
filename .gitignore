```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js
*.ts
*.tsx

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
.DS_Store
Thumbs.db

# Distribution / packaging
*.tar.gz
*.zip
*.gz

# Compiled Binary files
*.exe
*.dll
*.so
*.a
*.obj
*.out
*.class
```