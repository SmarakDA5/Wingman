```gitignore
# Dependencies
node_modules/
.pnpm-store/
.npm/
.yarn/

# Build outputs
dist/
build/
coverage/
.eslintcache

# Logs
*.log

# Environment variables
.env
.env.local
.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# OS generated
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# TypeScript/JavaScript
*.tsbuildinfo
*.js.map
*.jsx.map
*.ts.map

# Temporary files
*.tmp
*.temp
*.bak
*.orig
*.rej

# Archives
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z
*.bz2
*.xz
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
```